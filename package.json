{
  "name": "ruuvi-iot-ingestion",
  "version": "3.0.0",
  "description": "High-performance RuuviTag MQTT ingestion service for InfluxDB",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@influxdata/influxdb-client": "^1.35.0",
    "advlib-ble-manufacturers": "^1.15.2",
    "dotenv": "^16.6.1",
    "esbuild": "^0.27.4",
    "fastify": "^5.8.2",
    "json-schema-to-zod": "^2.7.0",
    "mqtt": "^5.3.3",
    "mysql2": "^3.20.0",
    "ojousima.ruuvi_endpoints.ts": "^4.0.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@types/node": "^20.19.37",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.18.0"
  }
}
